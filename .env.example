# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Required ────────────────────────────────────────────────────────────────

# GitHub Personal Access Token used to push the exported gallery.
# Create one at: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# Required permissions: Contents → Read and write (for your target repo only)
GITHUB_TOKEN=

# HTTPS URL of the git repository the gallery will be pushed to.
# e.g. https://github.com/your-username/your-repo.git
GITHUB_REPO_URL=

# ── Optional ─────────────────────────────────────────────────────────────────

# Audible region TLD. Defaults to "com" (audible.com).
# Other values: co.uk  de  fr  co.jp  com.au  ca  it  es  in  com.br
# AUDIBLE_DOMAIN=com

# Branch to push the gallery to. Defaults to "main".
# GITHUB_BRANCH=main
